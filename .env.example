# Copy to .env.local and fill in values. This file is committed as a reference.

# Supabase (client-safe — exposed to browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only — used by Vercel serverless functions, never in client bundle
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
RESEND_API_KEY=

# Email (Resend)
OWNER_EMAIL=              # where new-order alerts are sent
EMAIL_FROM=onboarding@resend.dev   # use a verified-domain address in production
REPLY_TO_EMAIL=          # where customer replies land (needs inbound/forwarding); defaults to OWNER_EMAIL
APP_URL=http://localhost:5173      # base URL for links in emails (prod: your domain)
